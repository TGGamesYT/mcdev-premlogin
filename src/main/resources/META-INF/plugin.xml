<idea-plugin>
    <id>dev.tggamesyt.mcdev-premlogin</id>
    <name>Minecraft OAuth</name>
    <version>1.8</version>
    <vendor email="tg@tggamesyt.dev" url="https://tggamesyt.dev">TGdoesCode</vendor>

    <description><![CDATA[
        Companion plugin for the Minecraft Dev plugin that lets you authenticate with a
        Microsoft (premium) account or set a cracked username before launching the Minecraft
        client from an IntelliJ run configuration.<br><br>
        Usage:<br>
        <url>
          <li>Download and install the latest version of <a href="https://plugins.jetbrains.com/plugin/8327-minecraft-development">Minecraft Development</a></li>
          <li>Download and install the lastest version of this plugin</li>
          <li>Open a Minecraft Development project, go to <b>Settings</b>, than <b>Minecraft Accounts</b></li>
          <li>Add your desired <b>Microsoft account</b> with the given <b>QR code or link</b>, or specify an <b>offline username</b></li>
          <li>And finally start the <b>Minecraft Client configuration</b></li>
        </ul>
    ]]></description>

    <depends>com.demonwav.minecraft-dev</depends>

    <extensions defaultExtensionNs="com.intellij">
        <projectConfigurable
                instance="dev.tggamesyt.MinecraftOAuthConfigurable"/>
        <applicationService
                serviceImplementation="dev.tggamesyt.MinecraftAccountsState"/>
        <postStartupActivity
                implementation="dev.tggamesyt.MinecraftProjectStartupActivity"/>
        <stepsBeforeRunProvider
                implementation="dev.tggamesyt.MinecraftBeforeRunTaskProvider"/>
    </extensions>

    <actions>
        <action id="MinecraftOAuthLoginAction"
                class="dev.tggamesyt.MinecraftOAuthLoginAction"
                text="Login to Minecraft"
                description="Login with Microsoft for premium Minecraft"/>

        <action id="MinecraftAccountsToolbarAction"
                class="dev.tggamesyt.MinecraftAccountsToolbarAction"
                icon="/icons/icon.png"
                text="Minecraft Accounts"
                description="Open the Minecraft accounts manager">
            <!-- Sit beside the run widget in the new-UI main toolbar. Must NOT go inside
                 RunToolbarMainActionGroup itself, which is a composite widget and breaks if
                 arbitrary actions are injected into it. -->
            <add-to-group group-id="MainToolbarRight" anchor="before" relative-to-action="RunToolbarMainActionGroup"/>
        </action>
    </actions>
</idea-plugin>
